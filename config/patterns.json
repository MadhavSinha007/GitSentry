{
  "version": 2,
  "entropy_threshold": 4.35,
  "high_entropy_min_length": 20,
  "high_entropy_string_regex": "[A-Za-z0-9_/\\+=\\.-]{20,}",
  "min_string_length": 16,
  "max_file_size_bytes": 1048576,
  "block_score_threshold": 85,
  "warn_score_threshold": 65,
  "scan_extensions": [
    ".c",
    ".cc",
    ".cpp",
    ".cxx",
    ".h",
    ".hpp",
    ".hh",
    ".cs",
    ".go",
    ".java",
    ".js",
    ".jsx",
    ".mjs",
    ".cjs",
    ".ts",
    ".tsx",
    ".py",
    ".rb",
    ".php",
    ".swift",
    ".kt",
    ".kts",
    ".rs",
    ".scala",
    ".sh",
    ".bash",
    ".zsh",
    ".yml",
    ".yaml",
    ".json",
    ".jsonc",
    ".toml",
    ".ini",
    ".cfg",
    ".conf",
    ".env",
    ".properties",
    ".xml",
    ".tf",
    ".tfvars",
    ".pem",
    ".key",
    ".crt",
    ".cer",
    ".p12",
    ".pfx",
    ".pub",
    ".txt",
    ".md",
    ".dockerfile",
    "Dockerfile"
  ],
  "ignore_paths": [
    ".git/",
    ".github/",
    "node_modules/",
    "third_party/",
    "vendor/",
    "dist/",
    "build/",
    "target/",
    "out/",
    "coverage/",
    ".next/",
    "tmp/",
    "temp/",
    "__pycache__/",
    "venv/",
    ".venv/",
    "site-packages/",
    "Pods/",
    "DerivedData/",
    ".idea/",
    ".vscode/",
    "package-lock.json",
    "yarn.lock",
    "pnpm-lock.yaml",
    "poetry.lock",
    "Cargo.lock",
    "composer.lock",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "test_value_keywords": [
    "tests",
    "testing",
    "dummy",
    "example",
    "sample",
    "mock",
    "fake",
    "placeholder",
    "changeme",
    "replace_me",
    "your_",
    "xxxx",
    "abc123"
  ],
  "sensitive_variable_keywords": [
    "secret",
    "token",
    "key",
    "apikey",
    "api_key",
    "access_key",
    "secret_key",
    "private_key",
    "client_secret",
    "client_id",
    "service_account",
    "session",
    "cookie",
    "authorization",
    "auth",
    "passwd",
    "password",
    "pwd",
    "bearer",
    "jwt",
    "refresh_token",
    "id_token",
    "webhook",
    "signing_secret"
  ],
  "allowlist_regexes": [
    "^AKIAIOSFODNN7EXAMPLE$",
    "^wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY$",
    "^AIza[0-9A-Za-z\\-_]{35}$",
    "^ghp_exampleexampleexampleexampleexample12$",
    "^xox[baprs]-example",
    "^-----BEGIN (RSA|EC|DSA|OPENSSH|PGP|PRIVATE|ENCRYPTED) PRIVATE KEY-----$"
  ],
  "patterns": [
    {
      "name": "AWS Access Key ID",
      "regex": "\\b(?:AKIA|ASIA)[0-9A-Z]{16}\\b",
      "confidence": 98,
      "severity": "critical"
    },
    {
      "name": "AWS Secret Access Key Assignment",
      "regex": "\\b(?:aws_)?secret(?:_access)?(?:_key)?\\b\\s*[:=]\\s*['\\\"]?([A-Za-z0-9/+=]{40})['\\\"]?",
      "confidence": 96,
      "severity": "critical"
    },
    {
      "name": "GitHub Token",
      "regex": "\\b(?:ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9_]{20,255}\\b",
      "confidence": 98,
      "severity": "critical"
    },
    {
      "name": "GitHub Fine-Grained PAT",
      "regex": "\\bgithub_pat_[A-Za-z0-9_]{20,255}\\b",
      "confidence": 99,
      "severity": "critical"
    },
    {
      "name": "GitLab Personal/Project/Group Access Token",
      "regex": "\\bgl(?:pat|ptt|cbt)-[A-Za-z0-9\\-_]{20,255}\\b",
      "confidence": 95,
      "severity": "critical"
    },
    {
      "name": "Slack Token",
      "regex": "\\bxox(?:b|p|a|r|s)-[A-Za-z0-9-]{10,200}\\b",
      "confidence": 96,
      "severity": "critical"
    },
    {
      "name": "Slack App-Level Token",
      "regex": "\\bxapp-[A-Za-z0-9-]{10,200}\\b",
      "confidence": 96,
      "severity": "critical"
    },
    {
      "name": "Stripe Secret Key",
      "regex": "\\bsk_(?:live|test)_[0-9A-Za-z]{16,255}\\b",
      "confidence": 97,
      "severity": "critical"
    },
    {
      "name": "Stripe Publishable/Restricted Key",
      "regex": "\\b(?:pk|rk)_(?:live|test)_[0-9A-Za-z]{16,255}\\b",
      "confidence": 80,
      "severity": "warning"
    },
    {
      "name": "Google API Key",
      "regex": "\\bAIza[0-9A-Za-z\\-_]{35}\\b",
      "confidence": 97,
      "severity": "critical"
    },
    {
      "name": "OpenAI API Key",
      "regex": "\\bsk-[A-Za-z0-9]{20,}\\b",
      "confidence": 92,
      "severity": "critical"
    },
    {
      "name": "OpenAI Project Key",
      "regex": "\\bsk-proj-[A-Za-z0-9_\\-]{20,}\\b",
      "confidence": 96,
      "severity": "critical"
    },
    {
      "name": "OpenAI Service Account Key",
      "regex": "\\bsk-svcacct-[A-Za-z0-9_\\-]{20,}\\b",
      "confidence": 96,
      "severity": "critical"
    },
    {
      "name": "JWT",
      "regex": "\\beyJ[A-Za-z0-9_-]{5,}\\.[A-Za-z0-9._-]{10,}\\.[A-Za-z0-9._-]{10,}\\b",
      "confidence": 90,
      "severity": "critical"
    },
    {
      "name": "Bearer Token",
      "regex": "\\bBearer\\s+[A-Za-z0-9\\-._~+/]+=*\\b",
      "confidence": 88,
      "severity": "critical"
    },
    {
      "name": "Basic Auth Credential",
      "regex": "\\bAuthorization\\b\\s*[:=]\\s*['\\\"]?Basic\\s+[A-Za-z0-9+/]{12,}={0,2}['\\\"]?",
      "confidence": 80,
      "severity": "warning"
    },
    {
      "name": "NPM Token",
      "regex": "\\bnpm_[A-Za-z0-9]{20,255}\\b",
      "confidence": 92,
      "severity": "critical"
    },
    {
      "name": "Twilio API Key SID",
      "regex": "\\bSK[0-9a-fA-F]{32}\\b",
      "confidence": 94,
      "severity": "critical"
    },
    {
      "name": "Twilio Account SID",
      "regex": "\\bAC[0-9a-fA-F]{32}\\b",
      "confidence": 70,
      "severity": "warning"
    },
    {
      "name": "SendGrid API Key",
      "regex": "\\bSG\\.[A-Za-z0-9_-]{16,}\\.[A-Za-z0-9_-]{16,}\\b",
      "confidence": 96,
      "severity": "critical"
    },
    {
      "name": "Discord Token",
      "regex": "\\b(?:mfa\\.[A-Za-z0-9_-]{20,}|[A-Za-z0-9_-]{24}\\.[A-Za-z0-9_-]{6}\\.[A-Za-z0-9_-]{20,})\\b",
      "confidence": 90,
      "severity": "critical"
    },
    {
      "name": "Shopify Access Token",
      "regex": "\\bshpat_[A-Za-z0-9]{20,255}\\b",
      "confidence": 95,
      "severity": "critical"
    },
    {
      "name": "Mailchimp API Key",
      "regex": "\\b[0-9a-f]{32}-us\\d{1,2}\\b",
      "confidence": 82,
      "severity": "warning"
    },
    {
      "name": "Firebase Cloud Messaging Server Key Assignment",
      "regex": "\\b(?:fcm|firebase).{0,20}\\b(?:server|legacy|api)?[_ -]?(?:key|token)\\b\\s*[:=]\\s*['\\\"]?AAAA[A-Za-z0-9_-]{20,}:[A-Za-z0-9_-]{20,}['\\\"]?",
      "confidence": 90,
      "severity": "critical"
    },
    {
      "name": "RSA/EC/DSA/OpenSSH Private Key Header",
      "regex": "-----BEGIN(?: RSA| EC| DSA| OPENSSH| PGP| ENCRYPTED)? PRIVATE KEY-----",
      "confidence": 100,
      "severity": "critical"
    },
    {
      "name": "SSH Public Key",
      "regex": "\\bssh-(?:rsa|ed25519|dss)\\s+[A-Za-z0-9+/]{40,}={0,3}(?:\\s+[\\w.@-]+)?",
      "confidence": 65,
      "severity": "warning"
    },
    {
      "name": "PEM / Certificate Block",
      "regex": "-----BEGIN CERTIFICATE-----",
      "confidence": 55,
      "severity": "info"
    },
    {
      "name": "Database URL",
      "regex": "\\b(?:postgres(?:ql)?|mysql|mongodb(?:\\+srv)?|redis|rediss|mssql|sqlserver|oracle|amqp|kafka):\\/\\/[^\\s'\\\"`]{8,}",
      "confidence": 88,
      "severity": "critical"
    },
    {
      "name": "Generic URI Credential",
      "regex": "\\b[a-z][a-z0-9+.-]{1,20}:\\/\\/[^\\/\\s:@]+:[^\\/\\s@]{6,}@[^ \\t\\r\\n'\\\"`]+",
      "confidence": 84,
      "severity": "critical"
    },
    {
      "name": "Private Key Assignment",
      "regex": "\\b(?:private[_-]?key|secret[_-]?key|signing[_-]?key)\\b\\s*[:=]\\s*['\\\"][^'\\\"]{16,}['\\\"]",
      "confidence": 85,
      "severity": "critical"
    },
    {
      "name": "Generic Secret Assignment",
      "regex": "\\b(?:secret|token|api[_-]?key|apikey|access[_-]?token|refresh[_-]?token|id[_-]?token|auth[_-]?token|client[_-]?secret|password|passwd|pwd|jwt|session[_-]?secret|webhook[_-]?secret|signing[_-]?secret|db[_-]?password|database[_-]?url)\\b[\\w.-]{0,24}\\s*[:=]\\s*['\\\"]?([A-Za-z0-9_/\\+=\\.-]{16,})['\\\"]?",
      "confidence": 82,
      "severity": "critical"
    },
    {
      "name": "Loose Sensitive Assignment",
      "regex": "\\b(?:key|sec|credential|auth|cookie|session)\\b[\\w.-]{0,24}\\s*[:=]\\s*['\\\"]?([A-Za-z0-9_/\\+=\\.-]{20,})['\\\"]?",
      "confidence": 68,
      "severity": "warning"
    },
    {
      "name": "Hex Secret in Sensitive Assignment",
      "regex": "\\b(?:secret|token|key|signature|digest|jwt|hash|sec)\\b[\\w.-]{0,24}\\s*[:=]\\s*['\\\"]?([a-f0-9]{32,128})['\\\"]?",
      "confidence": 78,
      "severity": "warning"
    },
    {
      "name": "Webhook URL with Secret",
      "regex": "https:\\/\\/hooks\\.[A-Za-z0-9.-]+\\/services\\/[A-Za-z0-9\\/_-]{16,}",
      "confidence": 90,
      "severity": "critical"
    }
  ],
  "generic_detectors": [
    {
      "name": "High Entropy Quoted String",
      "type": "quoted_string_entropy",
      "min_length": 20,
      "min_entropy": 4.5,
      "base_confidence": 62,
      "severity": "warning",
      "require_sensitive_context": false,
      "deny_if_variable_name_matches": [
        "id",
        "uuid",
        "guid",
        "sha",
        "sha1",
        "sha256",
        "md5",
        "etag",
        "version",
        "commit",
        "hash"
      ]
    },
    {
      "name": "High Entropy Sensitive Assignment",
      "type": "assignment_value_entropy",
      "min_length": 16,
      "min_entropy": 4.0,
      "base_confidence": 78,
      "severity": "critical",
      "variable_keywords": [
        "secret",
        "token",
        "key",
        "apikey",
        "api_key",
        "password",
        "passwd",
        "pwd",
        "auth",
        "jwt",
        "session",
        "cookie",
        "client_secret",
        "access_token",
        "refresh_token",
        "private_key",
        "webhook",
        "signing_secret"
      ]
    },
    {
      "name": "Long Base64-Like Blob",
      "type": "regex_entropy",
      "regex": "\\b(?:[A-Za-z0-9+/]{40,}={0,2})\\b",
      "min_length": 40,
      "min_entropy": 4.6,
      "base_confidence": 72,
      "severity": "warning"
    },
    {
      "name": "Long Hex Blob in Sensitive Context",
      "type": "regex_entropy",
      "regex": "\\b[a-f0-9]{32,128}\\b",
      "min_length": 32,
      "min_entropy": 3.2,
      "base_confidence": 70,
      "severity": "warning",
      "require_sensitive_context": true
    }
  ]
}